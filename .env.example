# ============================================================
# VPS Coffee — Variables de Entorno
#
# Este archivo es una REFERENCIA. Cada app tiene su propio .env.local:
#   apps/web/.env.local   → solo variables marcadas con [web]
#   apps/admin/.env.local → solo variables marcadas con [admin]
#
# IMPORTANTE: La mayoría de integraciones (Wompi, MercadoPago,
# Skydropx, Resend, WhatsApp) se configuran desde el panel admin
# en /configuracion — NO requieren variables de entorno.
# ============================================================

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Panel: https://supabase.com/dashboard → Project Settings → API
# Aplica a: [web] [admin]
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Stack Auth — Sitio web (compradores) ─────────────────────────────────────
# Proyecto: vps-coffee-web en https://app.stack-auth.com
# Aplica a: [web]
# IMPORTANTE: proyecto DIFERENTE al del admin para aislar sesiones.
NEXT_PUBLIC_HEXCLAVE_PROJECT_ID=your-web-stack-project-id
NEXT_PUBLIC_HEXCLAVE_PUBLISHABLE_CLIENT_KEY=pck_web_...
HEXCLAVE_SECRET_SERVER_KEY=ssk_web_...

# ─── Stack Auth — Panel admin ──────────────────────────────────────────────────
# Proyecto: vps-coffee-admin en https://app.stack-auth.com
# Aplica a: [admin]
# IMPORTANTE: proyecto DIFERENTE al del sitio web para aislar sesiones.
# Un admin logueado en el panel NO aparecerá como logueado en la tienda.
NEXT_PUBLIC_HEXCLAVE_PROJECT_ID=your-admin-stack-project-id
NEXT_PUBLIC_HEXCLAVE_PUBLISHABLE_CLIENT_KEY=pck_admin_...
HEXCLAVE_SECRET_SERVER_KEY=ssk_admin_...

# ─── URLs ─────────────────────────────────────────────────────────────────────
# Aplica a: [web]
NEXT_PUBLIC_SITE_URL=https://vpscoffee.com
# Aplica a: [admin] — usada en el link del email de invitación de nuevos usuarios
NEXT_PUBLIC_ADMIN_URL=https://admin.vpscoffee.com

# ─── Blog Draft Mode ────────────────────────────────────────────────────────────
# Secreto para activar la previsualización de artículos borrador.
# Aplica a: [web] (server) y [admin] (NEXT_PUBLIC para generar la URL en el cliente)
DRAFT_SECRET=cambia-este-secreto
NEXT_PUBLIC_DRAFT_SECRET=cambia-este-secreto

# ─── Stack Auth API (opcional) ────────────────────────────────────────────────
# Solo necesaria si Stack Auth cambia su URL base. Aplica a: [admin]
# NEXT_PUBLIC_STACK_API_URL=https://api.stack-auth.com

# ─── Modo mantenimiento ───────────────────────────────────────────────────────
# Aplica a: [web]
MAINTENANCE_MODE=false

# ============================================================
# Las siguientes integraciones NO usan variables de entorno.
# Se configuran desde el panel admin en /configuracion y se
# guardan en Supabase (bypasean el ciclo de redeploy):
#
#   Pasarelas de pago (Wompi, MercadoPago)
#     → Tabla: payment_config  (migración 5)
#
#   Emails transaccionales (Resend)
#     → Tabla: store_config    (migración 6)
#
#   Envíos (Skydropx — credenciales y tarifa fija)
#     → Tabla: shipping_config (migración 2)
#
#   WhatsApp, logo, nombre de la tienda
#     → Tabla: store_config    (migración 4)
# ============================================================
