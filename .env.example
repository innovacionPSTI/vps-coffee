# ============================================================
# VPS Coffee — Variables de Entorno
# Copia este archivo como .env.local en apps/web y apps/admin
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Stack Auth ---
NEXT_PUBLIC_STACK_PROJECT_ID=your-stack-project-id
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=pck_...
STACK_SECRET_SERVER_KEY=ssk_...

# --- Pasarelas de Pago ---
# Wompi (Bancolombia)
WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_PRIVATE_KEY=prv_test_...
WOMPI_EVENTS_SECRET=test_events_...

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxx
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxxxxxx

# --- Skydropx ---
SKYDROPX_BASE_URL=https://api-pro.skydropx.com
SKYDROPX_BASE_URL_SANDBOX=https://sb-pro.skydropx.com
SKYDROPX_CLIENT_ID=tu_client_id
SKYDROPX_CLIENT_SECRET=tu_client_secret
SKYDROPX_ADDRESS_FROM_ID=at_xxxxxxxxxxxx
SKYDROPX_WEBHOOK_SECRET=tu_webhook_secret

# --- WhatsApp ---
NEXT_PUBLIC_WHATSAPP_NUMBER=573XXXXXXXXX

# --- Resend (emails transaccionales) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=pedidos@vpscoffee.com

# --- URLs ---
NEXT_PUBLIC_SITE_URL=https://vpscoffee.com
NEXT_PUBLIC_ADMIN_URL=https://admin.vpscoffee.com

# --- Modo mantenimiento ---
MAINTENANCE_MODE=false
